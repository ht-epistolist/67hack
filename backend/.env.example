# ── OpenRouter (powers both the investigator agents and Cognee's LLM) ──
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...

# Google Vertex (Gemini) models, routed through OpenRouter where your Vertex
# integration key is enabled. Any OpenRouter model id works here.
# Cheap/fast model for the chatty specialist loops:
AGENT_MODEL=google/gemini-2.5-flash
# Stronger model for the Orchestrator + Synthesizer reasoning:
REASONING_MODEL=google/gemini-2.5-pro

# ── Cognee (shared agent memory / knowledge graph) ──
# LLM goes through OpenRouter; embeddings run LOCALLY via fastembed
# (OpenRouter has no embeddings endpoint), so no second key is needed.
# NOTE: the core memory path (write/recall) uses fastembed only — no tokens.
COGNEE_LLM_MODEL=openrouter/google/gemini-2.5-flash
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSIONS=384

# Optional: cap how many transfer edges get pushed into Cognee's graph
# (keeps first-run cognify fast). Set 0 for no cap.
COGNEE_MAX_EDGES=0
